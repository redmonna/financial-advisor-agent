# Google API Key for Gemini models and Search
GOOGLE_API_KEY=your_google_api_key_here

# Alpha Vantage API Key (Get a free one at alphavantage.co)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Gemini Model choice
AGENT_GEMINI_MODEL=gemini-3-flash-preview

# FRED API Key for housing/economic data (free at fred.stlouisfed.org)
FRED_API_KEY=your_fred_api_key_here

# BLS API Key for occupation wage/outlook data (free at bls.gov/developers)
BLS_API_KEY=your_bls_api_key_here

# O*NET API Key for skills/occupation data (free at services.onetcenter.org)
ONET_API_KEY=your_onet_api_key_here

# Port for the A2A service
AGENT_PORT=10000
